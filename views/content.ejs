<div>
  <div class="separator"></div>
  <div style="display:flex;flex-direction:column">
    <label class="label-to-top" style="display:block">Return external streams (they open in a browser) <input type="checkbox" id="externalStreams"<%= (config?.get("externalStreams"))?` checked="true"`:"" %>></label>
    <label class="full-width label-to-top" style="display:block" for="manifest_url">Your manifest URL:</label>
    <textarea class="form-element" id="manifest_url" rows="1"
      style="resize:none;overflow:hidden;text-align:center;font-size:unset;"
      readonly>https://pigamer37.alwaysdata.net/manifest.json</textarea>
      <!-- 'stremio://' + window.location.host + '/' + encodeURIComponent(JSON.stringify(config)) + '/manifest.json' -->
  </div>
  <button class="full-width" onclick="{navigator.clipboard.writeText(getElementById('manifest_url').value).then((e)=>{
          console.log('copied!');const origText=event.target.innerText;event.target.innerText='Copied!';setTimeout(function(){
            this.innerText=origText
        ;}.bind(event.target), 3000);}).catch((error)=>{console.error(error);})}">
    Copy manifest URL
  </button>
  <a id="installLink" class="install-link" href="#">
    <button tabindex="-1" class="full-width">Open In Stremio</button>
  </a>
  <script>const ta=document.getElementById('manifest_url');const externalStreams=document.getElementById('externalStreams')
    const installLink=document.getElementById('installLink')
    function genManifLink(){
      ta.innerText=`${window.location.origin}/${(externalStreams.checked)?"externalStreams=true/":""}manifest.json`
      installLink.href=ta.innerText.replace('https://','stremio://')
      ta.style.minHeight=ta.scrollHeight+"px"
    }
    externalStreams.addEventListener('input',()=>genManifLink())
    genManifLink()</script>
</div>